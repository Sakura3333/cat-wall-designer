{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://psd3.local/schemas/ai-cad/quality-report.v1.schema.json",
  "title": "QualityReportV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "jobId",
    "componentSpecRevision",
    "planHash",
    "compilerVersion",
    "blenderVersion",
    "status",
    "hardConstraintToleranceMm",
    "checks",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "jobId": { "type": "string", "minLength": 1 },
    "componentSpecRevision": { "type": "integer", "minimum": 1 },
    "planHash": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
    "compilerVersion": { "type": "string", "minLength": 1 },
    "blenderVersion": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "failed"] },
    "hardConstraintToleranceMm": { "type": "number", "exclusiveMinimum": 0 },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "status", "message"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "kind": { "enum": ["overall-size", "part-size", "hole-diameter", "hole-center", "topology", "gltf", "render"] },
          "status": { "enum": ["passed", "warning", "failed"] },
          "expectedMm": { "type": "number" },
          "actualMm": { "type": "number" },
          "deltaMm": { "type": "number", "minimum": 0 },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "fileName", "sha256", "sizeBytes"],
        "properties": {
          "kind": { "enum": ["glb", "blend", "bpy", "obj", "fbx", "stl", "thumbnail", "log"] },
          "fileName": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
          "sizeBytes": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
